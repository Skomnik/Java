<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="400.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.assessmentstartercode.warehousesystem.SpaceCapChangeController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Reorder Point">
        <font>
            <Font size="26.0" />
        </font>
    </Label>

    <GridPane hgap="10.0" vgap="10.0">
        <Label text="Choose item" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <ComboBox fx:id="itemComboBox" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Old Quantity:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="oldquantityField" promptText="0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="New Quantity:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="newquantityField" promptText="0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
         <RowConstraints />
        </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER" spacing="20.0">
        <Button defaultButton="true" onAction="#handleSell" prefWidth="100.0" text="Change" />
        <Button fx:id="Back" cancelButton="true" onAction="#onBackClick" prefWidth="100.0" text="Back" />
    </HBox>

    <Label fx:id="statusLabel" text="" textFill="gray" />
</VBox>
