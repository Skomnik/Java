<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="581.0" prefWidth="446.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.assessmentstartercode.warehousesystem.ManagerInsideController">
    <children>
        <Button fx:id="viewBuffer" layoutX="119.0" layoutY="88.0" mnemonicParsing="false" onAction="#onViewBufferClick" prefHeight="26.0" prefWidth="207.0" text="View all items in the Buffer" />
        <Button fx:id="viewShop" layoutX="119.0" layoutY="131.0" mnemonicParsing="false" onAction="#onViewShopClick" prefHeight="26.0" prefWidth="207.0" text="View of items on the sales floor" textAlignment="CENTER" wrapText="true" />
        <Button fx:id="Logout" layoutX="120.0" layoutY="475.0" mnemonicParsing="false" onAction="#onLogoutButtonClick" prefHeight="26.0" prefWidth="207.0" text="Log Out" />
        <Label layoutX="110.0" layoutY="39.0" prefHeight="40.0" prefWidth="226.0" text="Welcome Manager" textAlignment="CENTER">
            <font>
                <Font size="26.0" />
            </font></Label>
        <Button fx:id="Close" layoutX="119.0" layoutY="520.0" mnemonicParsing="false" onAction="#onCloseButtonClick" prefHeight="26.0" prefWidth="207.0" text="Close" />
        <Button fx:id="viewOrderBuffer" layoutX="119.0" layoutY="219.0" mnemonicParsing="false" onAction="#onViewOrderBufferClick" prefHeight="51.0" prefWidth="207.0" text="View and confirm list of items moves from buffer and accept" textAlignment="CENTER" wrapText="true" />
      <Button fx:id="RepPpointBtn" layoutX="119.0" layoutY="175.0" mnemonicParsing="false" onAction="#onRepPointButtonClick" prefHeight="26.0" prefWidth="207.0" text="Change replenishment point fot Item" />
      <Button fx:id="viewOrderSup" layoutX="119.0" layoutY="286.0" mnemonicParsing="false" onAction="#onViewOrderSupClick" prefHeight="51.0" prefWidth="207.0" text="View and Confirming automatic orders from external suppliers" textAlignment="CENTER" wrapText="true" />
      <Button fx:id="viewSalesBtn" layoutX="119.0" layoutY="352.0" mnemonicParsing="false" onAction="#onviewSalesButtonClick" prefHeight="26.0" prefWidth="207.0" text="View all sells" />
      <Button fx:id="addbtn" layoutX="120.0" layoutY="396.0" mnemonicParsing="false" onAction="#onAddButtonClick" prefHeight="26.0" prefWidth="207.0" text="Add new product" />
      <Button fx:id="delDtn" layoutX="121.0" layoutY="437.0" mnemonicParsing="false" onAction="#onDelButtonClick" prefHeight="26.0" prefWidth="207.0" text="Delete Item from systen" />
    </children>
</AnchorPane>
